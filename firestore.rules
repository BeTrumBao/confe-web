rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // Confe – Firestore Security Rules
    // Last updated: 2026-02-22
    // ======================================================

    // ── Helper Functions ──────────────────────────────────

    /** Returns true if the requester is signed in. */
    function isAuth() {
      return request.auth != null;
    }

    /** Returns true if the requester owns the document by UID. */
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── Collections ───────────────────────────────────────

    // 1. User Profiles
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // 2. Topics
    match /topics/{topicId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        (resource.data.authorId == request.auth.uid ||
         resource.data.owner   == request.auth.token.email);

      // Per-topic chat room
      match /chat/{docId} {
        allow read, write: if isAuth();
      }
      // Per-topic typing indicators
      match /typing/{docId} {
        allow read, write: if isAuth();
      }
    }

    // 3. Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        resource.data.authorUid == request.auth.uid;
    }

    // 4. Friend Requests
    match /friend_requests/{requestId} {
      allow read: if isAuth() &&
        (resource.data.from_uid == request.auth.uid ||
         resource.data.to_uid   == request.auth.uid);
      allow create: if isAuth() &&
        request.resource.data.from_uid == request.auth.uid;
      allow update, delete: if isAuth() &&
        (resource.data.from_uid == request.auth.uid ||
         resource.data.to_uid   == request.auth.uid);
    }

    // 5. Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth();

      // Emoji reactions – each user may only write their own reaction document.
      match /user_reactions/{uid} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == uid;
      }
    }

    // 6. Feedbacks
    match /feedbacks/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }

    // 7. Topic Membership
    // Open read/write to support both authenticated users and anonymous device IDs.
    match /topic_members/{docId} {
      allow read, create, update, delete: if true;
    }

    // 8. Join Requests (legacy – kept for backward compatibility)
    match /requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth();
    }

    // 9. Community Poll Votes
    match /community_votes/{pollId} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // 10. Public Chat & Typing
    match /public_chat/{docId} {
      allow read, write: if isAuth();
    }
    match /public_typing/{docId} {
      allow read, write: if isAuth();
    }

    // 11. Group Chats
    match /groups/{groupId} {
      allow read, write: if isAuth();
      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }

    // 12. Reports & Bug Reports
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }
    match /bug_reports/{reportId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }

    // 13. Click Game Leaderboard
    match /leaderboard_clicks/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }

    // 14. System Configuration (read-only from client)
    match /system/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Default: deny everything not explicitly covered above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
