rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======== Helper Functions ========

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ======== Collection Rules ========

    match /users/{userId} {
      allow read: if isAuth(); 

      // Allow any authenticated user (including anonymous) to create their own doc
      allow create: if isOwner(userId) && 
                      request.resource.data.get('isVerified', false) == false && 
                      request.resource.data.get('role', 'member') == 'member' && 
                      request.resource.data.get('isBanned', false) == false;
      
      // Admins can update anything.
      // Users can update their own doc BUT:
      //   - Cannot self-grant isVerified, role, isBanned, isChatMuted
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.get('isVerified', false) == resource.data.get('isVerified', false) &&
        request.resource.data.get('role', 'member') == resource.data.get('role', 'member') &&
        request.resource.data.get('isBanned', false) == resource.data.get('isBanned', false) &&
        request.resource.data.get('isChatMuted', false) == resource.data.get('isChatMuted', false)
      );
      allow delete: if isAdmin();

      match /chatRooms/{roomId} {
        allow read: if isOwner(userId);
        allow write: if isAuth();
      }

      match /friendRequests/{requestId} {
        allow read, write: if isOwner(userId) || (isAuth() && requestId == request.auth.uid);
      }
    }

    match /subjects/{subjectId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ======== BẢO MẬT UPDATE CHO OUTLINES ========
    match /outlines/{docId} {
      // Ai cũng xem được đề cương
      allow read: if isAuth();
      
      // Khi tạo mới: UID lưu trong payload bắt buộc phải là người đang login, chống giả mạo
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      
      // Khi cập nhật: Phải là Admin, HOẶC là tác giả và không được phép đổi tên tác giả sang người khác
      allow update: if isAdmin() || (
        isAuth() && 
        resource.data.uid == request.auth.uid && 
        request.resource.data.uid == request.auth.uid
      );
      
      allow delete: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
    }

    match /topics/{topicId} {
      allow read: if isAuth();
      allow create: if isAuth(); 
      allow update, delete: if isAdmin() || (isAuth() && resource.data.authorId == request.auth.uid);
      
      match /chat/{docId} { 
        allow read: if isAuth(); 
        allow write: if isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isChatMuted', false) == false;
      }
      
      match /typing/{docId} { 
        allow read, write: if isAuth(); 
      }
    }

    match /comments/{commentId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin() || (isAuth() && (resource.data.authorUid == request.auth.uid || resource.data.authorId == request.auth.uid));
    }

    match /friend_requests/{requestId} {
      allow read: if isAuth() && (resource.data.from_uid == request.auth.uid || resource.data.to_uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.from_uid == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuth() && (resource.data.from_uid == request.auth.uid || resource.data.to_uid == request.auth.uid));
    }

    match /friendships/{docId} {
      // Allowed if UID is in docId (for getDoc existence check) 
      // OR if UID is in the users array (for queries)
      allow read: if isAuth() && (
        docId.matches('.*' + request.auth.uid + '.*') || 
        (resource != null && request.auth.uid in resource.data.users)
      );
      
      allow create: if isAuth() && (
        docId.matches('.*' + request.auth.uid + '.*') || 
        request.auth.uid in request.resource.data.users
      );
      
      allow update: if isAuth() && request.auth.uid in resource.data.users && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['streak']) ||
        request.resource.data.streak == resource.data.streak + 1 ||
        request.resource.data.streak == 0
      );
      allow delete: if isAdmin() || (isAuth() && request.auth.uid in resource.data.users);
    }

    match /caro_rooms/{roomId} {
      allow read, write: if isAuth();
    }

    match /leaderboard_caro/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin() || (isAuth() && resource.data.authorUid == request.auth.uid);
      
      match /user_reactions/{uid} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == uid;
      }
    }

    match /feedbacks/{docId} { allow create: if isAuth(); allow read, update, delete: if isAdmin(); }
    match /reports/{reportId} { allow create: if isAuth(); allow read, update, delete: if isAdmin(); }
    match /bug_reports/{reportId} { allow create: if isAuth(); allow read, update, delete: if isAdmin(); }
    match /syllabus_feedback/{docId} { allow create: if isAuth(); allow read, update, delete: if isAdmin(); }
    match /topic_members/{docId} { allow read, create, update, delete: if isAuth(); }
    
    match /community_votes/{pollId} { allow read, write: if isAuth(); }
    
    match /public_chat/{docId} { 
      allow read: if isAuth(); 
      allow write: if isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isChatMuted', false) == false;
    }
    match /public_typing/{docId} { allow read, write: if isAuth(); }

    match /conversations/{conversationId} {
      allow read, write: if isAuth() && conversationId.matches('.*' + request.auth.uid + '.*');
      
      match /messages/{messageId} {
        allow read, write: if isAuth() && conversationId.matches('.*' + request.auth.uid + '.*');
      }
    }

    match /groups/{groupId} {
      allow read, update, delete: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth() && request.auth.uid in request.resource.data.members;
      match /messages/{messageId} { 
        allow read, write: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members; 
      }
    }
    
    match /leaderboard_clicks/{userId} { allow read: if isAuth(); allow create, update: if isAdmin() || isOwner(userId); }
    match /system/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /follows/{followId} { allow read, write: if isAuth(); }
    match /rps_rooms/{roomId} { allow read, write: if isAuth(); }
    match /pending_invites/{uid}/invites/{invId} { allow read, write: if isAuth(); }

    match /matchmaking_couples/{docId} {
      allow read, create: if isAuth();
      allow update: if isAdmin() || (
        isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'voters']) &&
        request.resource.data.get('voteCount', 0) == resource.data.get('voteCount', 0) + 1 &&
        request.resource.data.get('voters', []).hasAll(resource.data.get('voters', [])) &&
        request.resource.data.get('voters', []).size() == resource.data.get('voters', []).size() + 1 &&
        !(request.auth.uid in resource.data.get('voters', []))
      );
      allow delete: if isAdmin() || isOwner(resource.data.createdBy);
    }
    match /leaderboard_dino/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }
    match /badges/{badgeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /requests/{requestId} {
      allow create: if isAuth();
      allow read, update: if isAuth();
      allow delete: if isAdmin();
    }


    match /{document=**} {
      allow read, write: if false;
    }
  }
}
